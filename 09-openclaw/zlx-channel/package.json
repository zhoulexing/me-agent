{
  "name": "zlx-channel",
  "version": "0.1.0",
  "description": "Zlx webhook channel plugin for OpenClaw",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts"
    },
    "./channel-plugin-api": {
      "import": "./channel-plugin-api.ts"
    },
    "./api": {
      "import": "./api.ts"
    }
  },
  "files": [
    "*.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "channelId": "zlx",
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "dependencies": {
    "hono": "^4.12.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts"
  },
  "keywords": [
    "openclaw",
    "openclaw-channel",
    "plugin"
  ],
  "engines": {
    "node": ">=22.14.0"
  }
}
